<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบจัดการและเก็บข้อมูลแบบตาราง</title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* --- ตั้งค่าพื้นฐาน --- */
        * {
            box-sizing: border-box;
            font-family: 'Sarabun', sans-serif;
        }
        body {
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 1000px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

        /* --- ส่วนหัว --- */
        h2 {
            margin-top: 0;
            color: #2c3e50;
            border-bottom: 2px solid #edf2f7;
            padding-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* --- ฟอร์มกรอกข้อมูล --- */
        .input-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)) auto;
            gap: 15px;
            margin-bottom: 30px;
            background: #f8fafc;
            padding: 20px;
            border-radius: 8px;
            align-items: flex-end;
        }
        .form-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        .form-group label {
            font-weight: 600;
            font-size: 0.9em;
            color: #4a5568;
        }
        .form-group input, .form-group select {
            padding: 10px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            font-size: 1em;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-group input:focus, .form-group select:focus {
            border-color: #3182ce;
        }

        /* --- ปุ่มต่าง ๆ --- */
        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 6px;
            font-size: 1em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .btn-add {
            background-color: #3182ce;
            color: white;
            height: 42px;
        }
        .btn-add:hover { background-color: #2b6cb0; }
        
        .btn-delete {
            background-color: #e53e3e;
            color: white;
            padding: 5px 10px;
            font-size: 0.85em;
        }
        .btn-delete:hover { background-color: #c53030; }

        /* --- ส่วนตารางข้อมูล --- */
        .table-responsive {
            overflow-x: auto;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            margin-top: 10px;
        }
        th, td {
            padding: 12px 15px;
            border-bottom: 1px solid #e2e8f0;
        }
        th {
            background-color: #ebf8ff;
            color: #2b6cb0;
            font-weight: 600;
        }
        tr:hover {
            background-color: #f8fafc;
        }
        .no-data {
            text-align: center;
            color: #a0aec0;
            padding: 30px;
        }

        /* Badge สถานะ */
        .badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.85em;
            font-weight: 600;
        }
        .badge-general { background-color: #e2e8f0; color: #4a5568; }
        .badge-important { background-color: #fed7d7; color: #9b2c2c; }
        .badge-work { background-color: #feebc8; color: #9c4221; }
    </style>
</head>
<body>

<div class="container">
    <h2>📊 ระบบบันทึกข้อมูลตารางอัจฉริยะ</h2>
    
    <div class="input-form">
        <div class="form-group">
            <label for="inputName">ชื่อรายการ / ข้อมูล</label>
            <input type="text" id="inputName" placeholder="กรอกชื่อข้อมูล...">
        </div>
        
        <div class="form-group">
            <label for="inputCategory">หมวดหมู่</label>
            <select id="inputCategory">
                <option value="ทั่วไป">ทั่วไป</option>
                <option value="งาน">งาน</option>
                <option value="สำคัญมาก">สำคัญมาก</option>
            </select>
        </div>
        
        <div class="form-group">
            <label for="inputNote">หมายเหตุ / รายละเอียด</label>
            <input type="text" id="inputNote" placeholder="กรอกรายละเอียดเพิ่มเติม...">
        </div>
        
        <button class="btn btn-add" onclick="addData()">➕ เพิ่มข้อมูล</button>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th style="width: 8%">ลำดับ</th>
                    <th style="width: 35%">ชื่อรายการ</th>
                    <th style="width: 17%">หมวดหมู่</th>
                    <th style="width: 25%">หมายเหตุ / รายละเอียด</th>
                    <th style="width: 15%">จัดการ</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                </tbody>
        </table>
    </div>
</div>

<script>
    // โหลดข้อมูลเก่าจาก LocalStorage (ถ้ามี) ถ้าไม่มีให้เป็นอาร์เรย์ว่าง
    let dataList = JSON.parse(localStorage.getItem('myTableData')) || [];

    // ฟังก์ชันแสดงผลข้อมูลในตาราง
    function renderTable() {
        const tableBody = document.getElementById('tableBody');
        tableBody.innerHTML = ''; // เคลียร์ตารางเก่าก่อน

        if (dataList.length === 0) {
            tableBody.innerHTML = `<tr><td colspan="5" class="no-data">📭 ยังไม่มีข้อมูลในตาราง กรุณาเพิ่มข้อมูลด้านบน</td></tr>`;
            return;
        }

        dataList.forEach((item, index) => {
            // กำหนดสีของ Badge ตามหมวดหมู่
            let badgeClass = 'badge-general';
            if (item.category === 'สำคัญมาก') badgeClass = 'badge-important';
            if (item.category === 'งาน') badgeClass = 'badge-work';

            const row = `
                <tr>
                    <td>${index + 1}</td>
                    <td><strong>${item.name}</strong></td>
                    <td><span class="badge ${badgeClass}">${item.category}</span></td>
                    <td>${item.note || '-'}</td>
                    <td>
                        <button class="btn btn-delete" onclick="deleteData(${index})">🗑️ ลบ</button>
                    </td>
                </tr>
            `;
            tableBody.innerHTML += row;
        });
    }

    // ฟังก์ชันเพิ่มข้อมูลใหม่
    function addData() {
        const nameInput = document.getElementById('inputName');
        const categoryInput = document.getElementById('inputCategory');
        const noteInput = document.getElementById('inputNote');

        // เช็กก่อนว่ากรอกชื่อหรือยัง
        if (nameInput.value.trim() === '') {
            alert('❌ กรุณากรอกชื่อรายการก่อนครับ!');
            return;
        }

        // สร้าง Object ข้อมูลใหม่
        const newData = {
            name: nameInput.value,
            category: categoryInput.value,
            note: noteInput.value
        };

        // เพิ่มเข้าอาร์เรย์ และบันทึกลง LocalStorage
        dataList.push(newData);
        localStorage.setItem('myTableData', JSON.stringify(dataList));

        // เคลียร์ค่าในช่องอินพุต
        nameInput.value = '';
        noteInput.value = '';

        // อัปเดตตารางให้แสดงข้อมูลใหม่
        renderTable();
    }

    // ฟังก์ชันลบข้อมูล
    function deleteData(index) {
        if (confirm('⚠️ คุณแน่ใจใช่ไหมว่าจะลบข้อมูลแถวนี้?')) {
            dataList.splice(index, 1); // ลบข้อมูลตามตำแหน่ง index
            localStorage.setItem('myTableData', JSON.stringify(dataList)); // อัปเดตคลังข้อมูล
            renderTable(); // อัปเดตตาราง
        }
    }

    // สั่งให้ตารางทำงานและแสดงผลตอนโหลดหน้าเว็บครั้งแรก
    renderTable();
</script>

</body>
</html>
